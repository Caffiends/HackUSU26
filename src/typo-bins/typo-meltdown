#!/usr/bin/env bash
set -u

cleanup() {
  tput cnorm 2>/dev/null || true   # show cursor
  printf "\033[0m"                 # reset attributes
  echo
}
trap cleanup EXIT
trap 'echo; echo "[ABORT] Thermal monitor interrupted."; exit 0' SIGINT SIGTERM

beep() { printf "\a"; }

glitch_line() {
  tr -dc 'A-Za-z0-9!@#$%^&*()_+=-[]{};:,.<>/?|' </dev/urandom | head -c $((RANDOM % 40 + 25))
  echo
}

rows() { tput lines 2>/dev/null || echo 24; }
cols() { tput cols  2>/dev/null || echo 80; }

half_clear_bottom() {
  local r h
  r="$(rows)"
  h=$((r / 2))
  tput cup "$h" 0 2>/dev/null || true
  printf "\033[J"
}

random_cursor_jump() {
  local r c rr cc
  rr="$(rows)"; cc="$(cols)"
  r=$((RANDOM % rr))
  c=$((RANDOM % cc))
  tput cup "$r" "$c" 2>/dev/null || true
}

tput civis 2>/dev/null || true
clear

# --- Fixed "fake" core stats (always 105C)
TEMP=105

# Start with plausible-looking values that wobble
RPM=4200
LOAD=92
VCORE_MV=1180
PKG_W=145
TJMAX=100

while true; do
  # Fake jitter (still always 105C)
  RPM=$((RPM + (RANDOM % 600 - 250)))
  (( RPM < 1800 )) && RPM=1800
  (( RPM > 6200 )) && RPM=6200

  LOAD=$((LOAD + (RANDOM % 13 - 6)))
  (( LOAD < 70 )) && LOAD=70
  (( LOAD > 100 )) && LOAD=100

  VCORE_MV=$((VCORE_MV + (RANDOM % 40 - 20)))
  (( VCORE_MV < 980 )) && VCORE_MV=980
  (( VCORE_MV > 1320 )) && VCORE_MV=1320

  PKG_W=$((PKG_W + (RANDOM % 18 - 8)))
  (( PKG_W < 95 )) && PKG_W=95
  (( PKG_W > 210 )) && PKG_W=210

  # --- Top "real-looking" panel
  tput cup 0 0 2>/dev/null || true
  printf "\033[0m"
  echo "======================================================================="
  echo "   THERMAL MONITOR v2.4.7  |  SENSOR BUS: OK  |  MODE: FAILSAFE (SIM)  "
  echo "======================================================================="
  echo
  printf " CPU PACKAGE TEMP: %3d°C  (TjMax: %3d°C)   " "$TEMP" "$TJMAX"
  printf "FAN: %4d RPM   LOAD: %3d%%\n" "$RPM" "$LOAD"
  printf " VCORE: %4dmV     PACKAGE POWER: %3dW      THROTTLE: " "$VCORE_MV" "$PKG_W"
  printf "\033[31;1mACTIVE\033[0m\n"
  echo
  echo " Events:"
  echo "  - IA: PROCHOT asserted"
  echo "  - RING: clock modulation engaged"
  echo "  - PL1/PL2: limit exceeded (simulated)"
  echo "  - Thermal status: CRITICAL"
  echo
  echo " Advisory:"
  echo "  - Reduce workload immediately"
  echo "  - Verify heatsink contact / fan curve"
  echo "  - If condition persists: initiate controlled shutdown"
  echo

  # --- Bottom half chaos zone
  half_clear_bottom
  tput cup $(( ( $(rows) ) / 2 )) 0 2>/dev/null || true

  echo "[CRITICAL] Thermal runaway detected. Display integrity degraded."
  (( RANDOM % 2 == 0 )) && beep
  (( RANDOM % 3 == 0 )) && beep

  # Glitch burst
  for _ in {1..6}; do
    (( RANDOM % 4 == 0 )) && printf "\033[7m"  # invert sometimes
    glitch_line
    printf "\033[0m"
  done

  # Random flicker effects
  (( RANDOM % 4 == 0 )) && random_cursor_jump
  (( RANDOM % 5 == 0 )) && clear

  # Random interval: 0.8s–2.5s-ish (integer seconds for portability)
  sleep $((RANDOM % 3 + 1))
done
