#!/bin/bash

SEVERITY=$1

case $SEVERITY in
  1)
    echo "Server:  Unreliable-Human"
    echo "Address: 0.0.0.0#53"
    ;;
  2)
    echo "Non-authoritative answer: You are bad at this."
    ;;
  3)
    echo "Why are you using nslookup? Use dig. Oh wait, you can't type that either."
    ;;
  4)
    echo "dig told me you were coming. We both think you should take a break."
    ;;
  5)
    echo "Setting interactive mode... actually, I'm just going to ignore you."
    sleep 5
    ;;
  6)
    echo "Default Server: dig-is-better.org"
    echo "Address: 1.1.1.1"
    ;;
  7)
    echo "I'm randomly swapping your 'A' record queries for 'TXT' records containing insults."
    ;;
  8)
    echo "Stopping the DNS resolver service because you're clearly confused."
    sudo systemctl stop systemd-resolved 2>/dev/null
    ;;
  9)
    echo "I'm sending 10,000 queries for 'how-to-type.com' to your router. Hope it has a good firewall."
    for i in {1..100}; do nslookup how-to-type.com 8.8.8.8 > /dev/null & done
    ;;
  10)
    # The Nuclear Option: Port 53 Occupation
    echo "If you can't use DNS correctly, NO ONE GETS DNS."
    echo "Occupying Port 53 to prevent actual resolution."

    # Attempts to bind to port 53 so nothing else can use it
    # Requires sudo/root to bind to privileged ports
    sudo python3 -c "import socket; s=socket.socket(socket.AF_INET, socket.SOCK_STREAM); s.bind(('0.0.0.0', 53)); s.listen(1); import time; time.sleep(3600)" &

    echo "Port 53 is now mine. Good luck resolving 'google.com' now."
    ;;
  *)
    echo "Invalid severity. Connection timed out; no servers could be reached."
    ;;
esac
